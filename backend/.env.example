# Environment Variables for Royal Futsal Backend

# Server Configuration
NODE_ENV=development
PORT=3000

# ====================================
# DATABASE CONFIGURATION
# ====================================

# Option 1: LOCAL MongoDB (if installed on your computer)
MONGODB_URI=mongodb://localhost:27017/royal-futsal

# Option 2: MongoDB Atlas (Free Cloud Database) - RECOMMENDED FOR HOSTING
# Get your connection string from: https://cloud.mongodb.com
# Replace <username>, <password>, and <cluster-url> with your details
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/royal-futsal?retryWrites=true&w=majority

# Example MongoDB Atlas URI (replace with your actual credentials):
# MONGODB_URI=mongodb+srv://royalfutsal:yourpassword123@cluster0.mongodb.net/royal-futsal?retryWrites=true&w=majority

# ====================================
# CONTACT & NOTIFICATIONS
# ====================================

# WhatsApp Business API (optional - for automated messages)
WHATSAPP_API_KEY=your_whatsapp_api_key_here
WHATSAPP_PHONE_NUMBER=__________

# ====================================
# PAYMENT GATEWAYS (Optional - Add when ready)
# ====================================

# eSewa Configuration
ESEWA_MERCHANT_CODE=your_esewa_merchant_code
ESEWA_SECRET_KEY=your_esewa_secret_key
ESEWA_SUCCESS_URL=http://localhost:3000/api/payment/esewa/success
ESEWA_FAILURE_URL=http://localhost:3000/api/payment/esewa/failure

# Khalti Configuration
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_PUBLIC_KEY=your_khalti_public_key
KHALTI_SUCCESS_URL=http://localhost:3000/api/payment/khalti/success
KHALTI_FAILURE_URL=http://localhost:3000/api/payment/khalti/failure

# ====================================
# EMAIL SERVICE (Optional - for notifications)
# ====================================

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=Royal Futsal Nepal <noreply@royalfutsal.com>

# ====================================
# SECURITY
# ====================================

# JWT Secret for admin authentication (change this to a random string)
JWT_SECRET=change_this_to_a_random_secure_string_123456789

# Admin credentials (for future admin panel)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# ====================================
# FRONTEND URL
# ====================================

# Local development
FRONTEND_URL=http://localhost:5500

# Production (update when deployed)
# FRONTEND_URL=https://your-website.com

# ====================================
# INSTRUCTIONS
# ====================================

# 1. Copy this file to .env (remove .example)
# 2. Fill in your actual values
# 3. Never commit .env to version control
# 4. For MongoDB Atlas (recommended for hosting):
#    - Go to https://cloud.mongodb.com
#    - Create free account
#    - Create a cluster (free tier)
#    - Get connection string
#    - Replace MONGODB_URI above
